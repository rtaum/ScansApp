<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ScansApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Player">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="Root"
        Padding="18"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            ColumnSpacing="24"
            RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                Text="Player"
                FontSize="26"
                FontWeight="SemiBold" />

            <Slider
                x:Name="ImageSlider"
                Grid.Row="1"
                VerticalAlignment="Center"
                Minimum="0"
                Maximum="{Binding SliderMaximum}"
                Value="{Binding SliderValue, Mode=TwoWay}"
                IsEnabled="{Binding ArePlaybackControlsEnabled}" />

            <Grid
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding AvailableScanIds}"
                    SelectedItem="{Binding SelectedScanId, Mode=TwoWay}"
                    PlaceholderText="Select scan" />

                <Button
                    x:Name="LoadButton"
                    Grid.Column="1"
                    Command="{Binding LoadScanCommand}"
                    MinWidth="44"
                    MinHeight="36"
                    Padding="10,8">
                    <Image
                        x:Name="LoadButtonIcon"
                        Width="18"
                        Height="18" />
                </Button>
            </Grid>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="6"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="PreviousButton"
                        Command="{Binding PreviousImageCommand}"
                        MinWidth="44"
                        MinHeight="36"
                        Padding="10,8">
                        <Image
                            x:Name="PreviousButtonIcon"
                            Width="18"
                            Height="18" />
                    </Button>

                    <Button
                        x:Name="PlaybackButton"
                        Grid.Column="1"
                        MinWidth="44"
                        MinHeight="36"
                        Padding="10,8">
                        <Image
                            x:Name="PlaybackButtonIcon"
                            Width="18"
                            Height="18" />
                    </Button>

                    <Button
                        x:Name="NextButton"
                        Grid.Column="2"
                        Command="{Binding NextImageCommand}"
                        MinWidth="44"
                        MinHeight="36"
                        Padding="10,8">
                        <Image
                            x:Name="NextButtonIcon"
                            Width="18"
                            Height="18" />
                    </Button>

                    <Grid
                        Grid.Column="3"
                        ColumnSpacing="8"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Image
                            x:Name="SpeedIcon"
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center" />
                        <ComboBox
                            x:Name="SpeedComboBox"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding ArePlaybackControlsEnabled}"
                            ItemsSource="{Binding SpeedOptions}"
                            SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}" />
                    </Grid>

                    <Button
                        x:Name="KeyImageButton"
                        Grid.Column="4"
                        Command="{Binding GoToKeyImageCommand}"
                        MinWidth="44"
                        MinHeight="36"
                        Padding="10,8">
                        <Image
                            x:Name="KeyImageButtonIcon"
                            Width="18"
                            Height="18" />
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="10">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="PLANE A"
                        FontSize="12"
                        FontWeight="SemiBold" />
                    <Border
                        MinHeight="308"
                        Background="#8B8B8B"
                        CornerRadius="6">
                        <Grid>
                            <Image
                                x:Name="PlaneAImage"
                                Stretch="Uniform"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="PlaneAPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="Not loaded"
                                FontSize="18" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="10">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="PLANE B"
                        FontSize="12"
                        FontWeight="SemiBold" />
                    <Border
                        MinHeight="308"
                        Background="#8B8B8B"
                        CornerRadius="6">
                        <Grid>
                            <Image
                                x:Name="PlaneBImage"
                                Stretch="Uniform"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="PlaneBPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="Not loaded"
                                FontSize="18" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
