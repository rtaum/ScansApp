<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ScansApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Player">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="Root"
        Padding="20"
        RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="Player"
            FontSize="28"
            FontWeight="SemiBold" />

        <Grid
            Grid.Row="1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Slider
                x:Name="ImageSlider"
                Minimum="0"
                Maximum="{Binding SliderMaximum}"
                Value="{Binding SliderValue, Mode=TwoWay}"
                IsEnabled="{Binding ArePlaybackControlsEnabled}" />

            <Button
                x:Name="PreviousButton"
                Grid.Column="1"
                Command="{Binding PreviousImageCommand}"
                MinWidth="44"
                Padding="10,8">
                <Image
                    x:Name="PreviousButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>

            <Button
                x:Name="PlayButton"
                Grid.Column="2"
                Command="{Binding PlayCommand}"
                MinWidth="44"
                Padding="10,8">
                <Image
                    x:Name="PlayButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>

            <Button
                x:Name="PauseButton"
                Grid.Column="2"
                Command="{Binding PauseCommand}"
                MinWidth="44"
                Padding="10,8"
                Visibility="Collapsed">
                <Image
                    x:Name="PauseButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>

            <Button
                x:Name="NextButton"
                Grid.Column="3"
                Command="{Binding NextImageCommand}"
                MinWidth="44"
                Padding="10,8">
                <Image
                    x:Name="NextButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>

            <StackPanel
                Grid.Column="4"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <Image
                    x:Name="SpeedIcon"
                    Width="18"
                    Height="18" />
                <ComboBox
                    x:Name="SpeedComboBox"
                    Width="110"
                    IsEnabled="{Binding ArePlaybackControlsEnabled}"
                    ItemsSource="{Binding SpeedOptions}"
                    SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}" />
            </StackPanel>

            <Button
                x:Name="KeyImageButton"
                Grid.Column="5"
                Command="{Binding GoToKeyImageCommand}"
                MinWidth="44"
                Padding="10,8">
                <Image
                    x:Name="KeyImageButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>

            <ComboBox
                Grid.Column="6"
                ItemsSource="{Binding AvailableScanIds}"
                SelectedItem="{Binding SelectedScanId, Mode=TwoWay}"
                PlaceholderText="Select scan" />

            <Button
                x:Name="LoadButton"
                Grid.Column="7"
                Command="{Binding LoadScanCommand}"
                MinWidth="44"
                Padding="10,8">
                <Image
                    x:Name="LoadButtonIcon"
                    Width="18"
                    Height="18" />
            </Button>
        </Grid>

        <Grid
            Grid.Row="2"
            ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="PLANE A"
                        FontWeight="SemiBold" />
                    <Border
                        MinHeight="320"
                        Background="#8A8A8A"
                        CornerRadius="8">
                        <Grid>
                            <Image
                                x:Name="PlaneAImage"
                                Stretch="Uniform"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="PlaneAPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="Not loaded"
                                FontSize="18" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="PLANE B"
                        FontWeight="SemiBold" />
                    <Border
                        MinHeight="320"
                        Background="#8A8A8A"
                        CornerRadius="8">
                        <Grid>
                            <Image
                                x:Name="PlaneBImage"
                                Stretch="Uniform"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="PlaneBPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="Not loaded"
                                FontSize="18" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
